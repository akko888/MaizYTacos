; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Ajolotazo"
config/description="Maíz y Tacos is a mobile fighting game based on gestures as movements. It is set in the mexican culture and references!"
run/main_scene="uid://b55mimj1gd1ot"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="uid://bhnaejibko4nv"

[autoload]

GameData="*uid://ceq3dj6x4re2y"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[gui]

theme/custom_font="uid://dtrmstppu8bof"

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_physics/layer_1="World"
2d_physics/layer_2="Hitbox"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
viewport/hdr_2d=true
